{
  "name": "@dreamer/test",
  "version": "1.1.6",
  "license": "Apache-2.0",
  "exports": {
    ".": "./src/mod.ts",
    "./browser": "./src/browser/mod.ts"
  },
  "publish": {
    "include": [
      "src/**/*.ts",
      "src/**/*.json",
      "LICENSE",
      "NOTICE",
      "README.md"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/test/**",
      "**/tests/**",
      "package.json"
    ]
  },
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any",
        "no-unresolved"
      ]
    }
  },
  "imports": {
    "@dreamer/i18n": "jsr:@dreamer/i18n@^1.0.1",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.0.18",
    "@dreamer/esbuild": "jsr:@dreamer/esbuild@^1.1.7",
    "@dreamer/logger": "jsr:@dreamer/logger@^1.0.3",
    "playwright": "npm:playwright@^1.59.1"
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "pw:install": "npx -y playwright@1.59.1 install chromium",
    "pw:install:firefox": "npx -y playwright@1.59.1 install firefox",
    "test:browser:smoke": "deno test -A tests/browser/browser-context.test.ts --filter 应该创建浏览器上下文",
    "test:browser:ci-like": "env CI=true deno test -A --no-check tests/browser/browser-context.test.ts --filter 应该创建浏览器上下文"
  }
}
